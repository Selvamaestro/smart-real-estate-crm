# ============================================================
#  Maestrominds CRM — Environment Variables
#  Copy this file to backend/.env and fill in your values.
# ============================================================

# ── MongoDB ──────────────────────────────────────────────────
# Your MongoDB Atlas (or local) connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────
# Any long random string — keep this secret!
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRE=7d

# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS / Frontend URL ──────────────────────────────────────
# Dev: Vite default port. Change in production to your deployed URL.
FRONTEND_URL=http://localhost:5173

# ── Email (optional — used for password-change notifications) ─
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
# Use a Gmail App Password (not your regular password)
EMAIL_PASSWORD=your-app-password

# ── Google OAuth (optional) ───────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
